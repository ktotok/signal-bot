# Copy to .env and fill in. NEVER commit .env.

# Your Signal account number (the account the bot is linked to), E.164 format.
PHONE_NUMBER=+15551234567

# ntfy topic to publish to. Use a long, RANDOM value — public topics are
# readable by anyone who knows the name.
NTFY_TOPIC=signal-fwd-change-me-to-something-random

# Optional: ntfy server (default https://ntfy.sh) and auth token for a
# reserved/self-hosted topic.
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOKEN=tk_xxxxxxxxxxxxxxxx

# Optional: reply in Signal after each forward ("true"/"false"). Default true.
# REPLY_ON_SUCCESS=true

# Address of the signal-cli-rest-api service, no protocol. In docker-compose
# this is set for you (signal-api:8080); only override for a non-compose setup.
# SIGNAL_SERVICE=signal-api:8080
