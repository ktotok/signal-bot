# Copy to .env and fill in. NEVER commit .env.

# Your Signal account number (the account the bot is linked to), E.164 format.
PHONE_NUMBER=+15551234567

# --- Where messages are forwarded ------------------------------------------
# TARGET_URL is the full endpoint URL, e.g. an ntfy topic:
#   https://ntfy.sh/<your-random-topic>
# For a public ntfy topic use a long, RANDOM name — anyone who knows it can read it.
TARGET_URL=https://ntfy.sh/signal-fwd-change-me-to-something-random

# TARGET_TYPE selects the client. Defaults to "ntfy" (the only built-in). Other
# endpoint types can be added in code via targets.register() — see README.
# TARGET_TYPE=ntfy

# Optional: bearer token sent as Authorization header (reserved/self-hosted
# ntfy topic, etc.).
# TARGET_TOKEN=tk_xxxxxxxxxxxxxxxx

# Optional: reply in Signal after each forward ("true"/"false"). Default true.
# REPLY_ON_SUCCESS=true

# Address of the signal-cli-rest-api service, no protocol. In docker-compose
# this is set for you (signal-api:8080); only override for a non-compose setup.
# SIGNAL_SERVICE=signal-api:8080

# --- Legacy (still supported) ----------------------------------------------
# If TARGET_URL is unset, the old ntfy variables are used to build the URL:
#   NTFY_TOPIC (required), NTFY_SERVER (default https://ntfy.sh), NTFY_TOKEN.
